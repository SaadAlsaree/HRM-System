# Copy to .env.local and fill real values. .env.local is gitignored.
#
# NextAuth + Keycloak (BFF)
AUTH_SECRET=                            # generate: openssl rand -base64 32  (REQUIRED in production)
AUTH_KEYCLOAK_SECRET=                   # Keycloak client secret (confidential client)
INTERNAL_PROXY_KEY=                     # shared secret for X-Internal-Proxy-Key header (must match backend ProxySettings:ApiKey)

# Override non-secret defaults here if needed (defaults live in .env)
# AUTH_KEYCLOAK_ISSUER=
# AUTH_KEYCLOAK_ISSUER_INTERNAL=
# AUTH_KEYCLOAK_ID=
# API_URL=
